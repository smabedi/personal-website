# 1. SECURITY: Prevent directory listing (people seeing your file structure)
Options -Indexes

# 2. SECURITY: Prevent access to hidden files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 3. PERFORMANCE: Leverage Browser Caching (Speed up return visits)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType font/woff2 "access plus 1 month"
    # For icons
    ExpiresByType image/x-icon "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
</IfModule>

# 4. PERFORMANCE: Gzip Compression (Smaller files = faster load)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>

AddType image/svg+xml .svg
# 5. ADD MIME TYPES (Ensures server knows exactly what these files are)
AddType image/x-icon .ico
AddType image/png .png
AddType image/svg+xml .svg
